#include "raylib.h"

#define SCREEN_WIDTH 1280
#define SCREEN_HEIGHT 720



int main(void)
{
    // Configure the window before creating it
    SetConfigFlags(
        FLAG_WINDOW_RESIZABLE |
        FLAG_MSAA_4X_HINT |
        FLAG_VSYNC_HINT
    );

    // Create window
    InitWindow(SCREEN_WIDTH, SCREEN_HEIGHT, "WSB"); //open world sandbox will be window name mean game or application name 

    // Run at 60 FPS if VSync is unavailable
    SetTargetFPS(60);

    while (!WindowShouldClose())
    {
        BeginDrawing();

        ClearBackground(BLACK);

        DrawText("WSB", 20, 20, 30, GREEN);// void DrawText(const char *text, int posX, int posY, int fontSize, Color color);
        DrawFPS(20, 60); //void DrawFPS(int posX, int posY);

        EndDrawing();
    }

    CloseWindow();

    return 0;
}
